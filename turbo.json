{
  "$schema": "https://turborepo.org/schema.json",
  "pipeline": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "@brainspark/shared-types#build": {
      "outputs": ["dist/**"]
    },
    "@brainspark/api-client#build": {
      "dependsOn": ["@brainspark/shared-types#build"],
      "outputs": ["dist/**"]
    },
    "@brainspark/typescript-config#build": {
      "cache": false
    },
    "@brainspark/eslint-config#build": {
      "cache": false
    },
    "@brainspark/student#build": {
      "dependsOn": ["@brainspark/shared-types#build", "@brainspark/api-client#build"],
      "outputs": ["dist/**"]
    },
    "@brainspark/parent#build": {
      "dependsOn": ["@brainspark/shared-types#build", "@brainspark/api-client#build"],
      "outputs": ["dist/**"]
    },
    "@brainspark/teacher#build": {
      "dependsOn": ["@brainspark/shared-types#build", "@brainspark/api-client#build"],
      "outputs": ["dist/**"]
    },
    "@brainspark/operator#build": {
      "dependsOn": ["@brainspark/shared-types#build", "@brainspark/api-client#build"],
      "outputs": ["dist/**"]
    }
  }
}