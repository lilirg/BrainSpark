# BrainSpark 环境变量配置
# 复制此文件为 .env 并根据实际环境修改

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=brainspark_dev
MYSQL_DATABASE=brainspark

# ============================================
# MongoDB 配置
# ============================================
MONGODB_URI=mongodb://brainspark:brainspark_dev@localhost:27017/brainspark_events
MONGODB_DB=brainspark_events

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=brainspark_dev
REDIS_DB=0

# ============================================
# ClickHouse 配置
# ============================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=brainspark
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ============================================
# Milvus 向量数据库配置
# ============================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=brainspark_knowledge

# ============================================
# MinIO 对象存储配置
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=brainspark

# ============================================
# JWT 配置（生产环境必须修改为随机生成的密钥）
# ============================================
JWT_SECRET=brainspark-jwt-secret-key-change-in-production
JWT_ACCESS_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800
JWT_ALGORITHM=HS256

# ============================================
# AI 服务配置
# ============================================
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TIMEOUT=60
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ============================================
# 应用配置
# ============================================
APP_NAME=BrainSpark
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO