# BrainSpark 后端服务环境变量配置

# 应用配置
APP_NAME=BrainSpark Backend
APP_VERSION=0.1.0
DEBUG=true
ENV=dev

# 服务端口
HOST=0.0.0.0
PORT=8080

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=brainspark
DB_PASSWORD=brainspark_dev
DB_NAME=brainspark
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# MongoDB 配置
MONGO_URI=mongodb://localhost:27017
MONGO_DB=brainspark

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ClickHouse 配置
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=brainspark

# JWT 配置（重要：生产环境必须修改为随机生成的密钥）
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI 服务配置
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TIMEOUT=60

# 功能开关
ENABLE_TODAY_TASKS=false

# 日志配置
LOG_LEVEL=INFO